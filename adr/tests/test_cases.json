{
  "skill": "adr",
  "description": "Functional tests for adr (Architecture Decision Records, CI tier)",
  "tests": [
    {
      "name": "Creates ADR with standard template",
      "description": "Should create adr/NNNN-title.md with status/context/decision/consequences",
      "assertions": [
        {
          "category": "file",
          "type": "matches_pattern",
          "pattern": "adr/\\d{4}-.+\\.md"
        },
        {
          "category": "content",
          "type": "contains_sections",
          "sections": ["Status", "Context", "Decision", "Consequences"]
        }
      ]
    }
  ]
}
